# ============================================================
#  HRMS 环境变量配置
#  复制本文件为 .env 并填入实际值:  cp .env.example .env
# ============================================================

# ---- 必填: 安全密钥 ----

# AES-256-GCM 加密密钥，必须恰好 32 字节（32 个 ASCII 字符）
# 用于加密身份证号、手机号、银行卡号等敏感字段
# ⚠️ 生产环境务必使用随机生成的强密钥
HRMS_AES_KEY=your-32-byte-aes-key-here!!!!!

# JWT 签名密钥，≥ 32 字符
# 用于签发和验证 access/refresh token
# ⚠️ 生产环境务必使用随机生成的强密钥
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long

# ---- 数据库配置 (PostgreSQL) ----

# PostgreSQL 数据库名
PG_DATABASE=hrms

# PostgreSQL 用户名
PG_USERNAME=hrms

# PostgreSQL 密码
# ⚠️ 生产环境务必使用强密码
PG_PASSWORD=hrms

# PostgreSQL 宿主机端口映射（避免与本机 PG 冲突）
PG_PORT=5432

# ---- 应用配置 ----

# Spring 激活的 Profile: pg (PostgreSQL) / h2 (内存数据库)
SPRING_PROFILES_ACTIVE=pg

# 后端 API 宿主机端口
APP_PORT=8080

# 前端宿主机端口
FRONTEND_PORT=80

# CORS 允许的来源（逗号分隔），部署后改为实际域名
HRMS_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# 是否启用 Swagger / OpenAPI 文档
# 生产环境建议 false
SWAGGER_ENABLED=false

# ---- Snowflake ID 生成器（多实例部署时各实例需不同值）----

HRMS_SNOWFLAKE_WORKER_ID=1
HRMS_SNOWFLAKE_DATACENTER_ID=1
